    "phutho_source_hash": "bfd1c197b1dd1a432a14740747bb37df2ddd5f7787444cbfc115fea59ace89a2",
    "phutho_source_url": "https://congan.phutho.gov.vn/article/thu-tuc-hanh-chinh/Cap-the-thuong-tru-cho-nguoi-nuoc-ngoai-tai-Viet-1332-17",
