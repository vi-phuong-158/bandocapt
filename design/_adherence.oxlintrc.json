{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/chat/**",
              "components/data/**",
              "components/forms/**",
              "ui_kits/ban-do-cong-an/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Be Vietnam Pro|Material Symbols Outlined))/i]",
        "message": "Font not provided by the design system. Available: Be Vietnam Pro, Material Symbols Outlined."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|soft|icon|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, soft, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:primary|amber|nearby|neutral)$/]",
        "message": "<Badge> tone must be one of 'primary' | 'amber' | 'nearby' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|fullWidth|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, fullWidth, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|amber|soft)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'amber' | 'soft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|children|label|avatar|disclaimer|style|key|ref|className|style|children)$/]",
        "message": "<ChatBubble> doesn't accept that prop. Declared props: role, children, label, avatar, disclaimer, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:assistant|user)$/]",
        "message": "<ChatBubble> role must be one of 'assistant' | 'user'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatLauncher'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|sublabel|avatar|icon|pulse|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ChatLauncher> doesn't accept that prop. Declared props: label, sublabel, avatar, icon, pulse, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|glass|icon|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, tone, glass, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:nearby|primary|amber|neutral)$/]",
        "message": "<Chip> tone must be one of 'nearby' | 'primary' | 'amber' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|color|key|ref|className|style|children)$/]",
        "message": "<FilterOption> doesn't accept that prop. Declared props: id, label, icon, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|size|fill|label|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, variant, size, fill, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|soft|glass|fab|scrim)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'soft' | 'glass' | 'fab' | 'scrim'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='InfoRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|value|href|style|key|ref|className|style|children)$/]",
        "message": "<InfoRow> doesn't accept that prop. Declared props: icon, label, value, href, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResultCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|address|type|distance|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ResultCard> doesn't accept that prop. Declared props: title, address, type, distance, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResultCard'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:police|cccd)$/]",
        "message": "<ResultCard> type must be one of 'police' | 'cccd'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|icon|style|key|ref|className|style|children)$/]",
        "message": "<SearchBar> doesn't accept that prop. Declared props: placeholder, icon, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
